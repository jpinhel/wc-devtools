{
  "name": "wc-devtools",
  "description": "Browser DevTools extension for inspecting and debugging Web Components — properties, attributes, methods, events, shadow DOM, live editing.",
  "version": "0.5.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "author": "Jeremy Pinhel",
  "keywords": [
    "web-components",
    "shadow-dom",
    "devtools",
    "browser-extension",
    "chrome-extension",
    "lit",
    "stencil",
    "fast",
    "inspector",
    "debugging"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jpinhel/wc-devtools.git"
  },
  "homepage": "https://github.com/jpinhel/wc-devtools#readme",
  "bugs": {
    "url": "https://github.com/jpinhel/wc-devtools/issues"
  },
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "wxt prepare && (git config core.hooksPath .githooks || true)",
    "playground": "bun build playground/src/page-components.js --outfile playground/page-components.js && bun playground/serve.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@lit-labs/virtualizer": "^2.1.1",
    "lit": "^3.3.3"
  },
  "overrides": {
    "@codemirror/state": "^6.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@lit-labs/signals": "^0.3.0",
    "@lit/task": "^1.0.3",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.1.43",
    "@types/jsdom": "^28.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  }
}
