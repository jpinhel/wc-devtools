{
  "languages": {
    "TypeScript": {
      "language_servers": ["biome", "!typescript-language-server", "!eslint"],
      "formatter": {
        "language_server": { "name": "biome" }
      },
      "format_on_save": "on"
    },
    "JavaScript": {
      "language_servers": ["biome", "!typescript-language-server", "!eslint"],
      "formatter": {
        "language_server": { "name": "biome" }
      },
      "format_on_save": "on"
    },
    "Vue": {
      "language_servers": ["vue-language-server", "!eslint"],
      "formatter": "language_server",
      "format_on_save": "on"
    }
  },
  "lsp": {
    "biome": {}
  }
}
